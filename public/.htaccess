# Trendora static export — Hostinger (Apache/LiteSpeed) config
# Lives in /public so `next build` copies it into /out on every export.

# Serve folder/index.html for clean URLs (Next trailingSlash output)
DirectoryIndex index.html

# Custom 404 (Next exports the not-found page to /404.html)
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS (SSL is already active on this domain)
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Gzip text assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Long-cache Next's fingerprinted assets; keep HTML fresh
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|webp|jpe?g|png|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
